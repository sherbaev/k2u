# apps/backend/.env.example
# Copy to .env and fill in real values for local development / deployment.

# HTTP port the NestJS server listens on.
PORT=3000

# MongoDB connection string (time-series telemetry, aggregates, events, etc).
MONGO_URI=mongodb://localhost:27017/k2u

# MQTT broker URL the ingestion service subscribes to (site/{siteId}/dev/{devId}/#).
MQTT_URL=mqtt://localhost:1883

# Secret used to sign/verify JWTs for authenticated API access. Change in every environment.
JWT_SECRET=change-me

# Telegram bot token used to send WARNING/CRITICAL alert notifications. Leave blank to disable.
TELEGRAM_TOKEN=

# Telegram chat/channel ID that receives alert notifications. Leave blank to disable.
TELEGRAM_CHAT_ID=

# Base URL of the AI/RUL-prediction microservice.
AI_URL=http://localhost:8000

# Allowed origin for CORS (frontend dev server).
CORS_ORIGIN=http://localhost:5173

# --- Auth (JWT) ---
# When true, write endpoints require a Bearer token (POST /api/auth/login).
# Left false by default so the no-hardware demo works out of the box.
AUTH_REQUIRED=false
# On first boot, if the users collection is empty and this is set, an admin is seeded.
SEED_ADMIN_USER=admin
SEED_ADMIN_PASSWORD=

# Raw telemetry TTL (days) before auto-deletion; aggregates are kept long-term.
RAW_TTL_DAYS=90
